#!/bin/bash
# Wrapper that makes urlx look like curl to runtests.pl
# 1. Translates --version output to curl-compatible format
# 2. Strips flags that urlx doesn't support yet (e.g. -q)
# 3. Overrides default User-Agent to match curl's format

URLX="${URLX_BIN:-$(dirname "$0")/../target/release/urlx}"
# Extract version from urlx --version output (first word after "urlx ")
VERSION=$("$URLX" --version 2>&1 | head -1 | awk '{print $2}')

if [ "$1" = "--version" ]; then
    # Get urlx version and translate branding to curl-compatible format
    # for the test runner (runtests.pl expects "curl <ver> ... libcurl/<ver> ...")
    "$URLX" --version 2>&1 | sed -e 's/^urlx /curl /' -e 's/liburlx\//libcurl\//'
    exit 0
fi

# Filter out unsupported flags and check for explicit User-Agent
args=()
has_user_agent=false
stderr_to_stdout=false
stderr_to_file=""
skip_next=false
skip_next_passthrough=""
for arg in "$@"; do
    if $skip_next; then
        skip_next=false
        if [ -n "$skip_next_passthrough" ]; then
            # Pass through both the flag and its value unchanged
            args+=("$skip_next_passthrough" "$arg")
            skip_next_passthrough=""
        else
            # Check if this is the value for --stderr
            if [ "$arg" = "-" ]; then
                stderr_to_stdout=true
            else
                stderr_to_file="$arg"
            fi
        fi
        continue
    fi
    case "$arg" in
        -q) ;; # urlx has no .curlrc, -q is a no-op
        -A|--user-agent) has_user_agent=true; args+=("$arg") ;;
        --stderr) skip_next=true; skip_next_passthrough="" ;;
        --unix-socket|--abstract-unix-socket) skip_next=true; skip_next_passthrough="$arg" ;;
        *)  args+=("$arg") ;;
    esac
done

# Inject curl-compatible User-Agent if not explicitly set
if [ "$has_user_agent" = false ]; then
    args=("-A" "curl/${VERSION}" "${args[@]}")
fi

# Run urlx, translating "urlx:" to "curl:" in stderr for test compatibility
# When --stderr - is used, redirect translated stderr to stdout
# When --stderr <file> is used, redirect translated stderr to the file
if $stderr_to_stdout; then
    "$URLX" "${args[@]}" 2>&1
elif [ -n "$stderr_to_file" ]; then
    "$URLX" "${args[@]}" 2>"$stderr_to_file"
else
    # Use a temp file to avoid bash process substitution hangs
    _stderr_tmp=$(mktemp)
    "$URLX" "${args[@]}" 2>"$_stderr_tmp"
    _exit_code=$?
    sed 's/^urlx:/curl:/' "$_stderr_tmp" >&2
    rm -f "$_stderr_tmp"
    exit $_exit_code
fi
